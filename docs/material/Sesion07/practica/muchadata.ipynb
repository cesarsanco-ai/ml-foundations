        "descripcion": "Predicción de precios de casas"
    },
    {
        "nombre": "Wine Quality (Calidad del vino)",
        "cargador": "openml",
        "id": 44136,
        "descripcion": "Predicción de calidad de vino (0-10)"
    },
    
    # === CLASIFICACIÓN MULTICLASE ===
    {
        "nombre": "Covertype (Cobertura forestal)",
        "cargador": "sklearn_multi",
        "func": fetch_covtype,
        "descripcion": "Clasificación de tipos de cobertura vegetal"
    },
    {
