        "id": 44089,
        "descripcion": "Riesgo crediticio / impago de préstamos"
    },
    {
        "nombre": "Adult Census (Ingreso >50K)",
        "cargador": "openml",
        "id": 1590,
        "descripcion": "Predicción de ingreso anual >50K"
    },
    {
        "nombre": "Credit Card Fraud (FinBench)",
        "cargador": "huggingface",
