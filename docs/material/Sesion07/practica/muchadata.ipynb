        "func": load_iris,
        "descripcion": "Clasificación de especies de iris"
    },
]

# ======================================================
# FUNCIONES DE CARGA POR TIPO
# ======================================================
def cargar_openml(id_ds):
    """Carga dataset desde OpenML"""
    data = fetch_openml(data_id=id_ds, as_frame=True)
    return data.data, data.target

def cargar_sklearn_reg(func):
    """Carga dataset de regresión desde sklearn"""
    data = func(as_frame=True)
    return data.data, data.target

def cargar_sklearn_multi(func):
    """Carga dataset de clasificación multiclase desde sklearn"""
    data = func(as_frame=True)
    return data.data, data.target

def cargar_huggingface(id_ds, subset=None):
    """Carga dataset desde Hugging Face"""
    if subset:
        dataset = load_dataset(id_ds, data_files=subset, split="train")
    else:
        dataset = load_dataset(id_ds, split="train")
    df = dataset.to_pandas()
    # Asumimos que la última columna es el target (ajustable)
    target = df.iloc[:, -1]
    features = df.iloc[:, :-1]
    return features, target

# ======================================================
# VALIDACIÓN MASIVA
# ======================================================
print("="*80)
print("VALIDACIÓN MASIVA DE DATASETS ONLINE PARA ML")
print("="*80)
print("📊 Verificando disponibilidad y estructura de cada dataset...\n")

resultados = []

for ds in datasets_to_test:
    print(f"\n{'─'*60}")
    print(f"🔍 Probando: {ds['nombre']}")
    print(f"📝 Descripción: {ds['descripcion']}")
    
    try:
        # Cargar según el tipo
        if ds['cargador'] == 'openml':
            X, y = cargar_openml(ds['id'])
        elif ds['cargador'] == 'sklearn_reg':
            X, y = cargar_sklearn_reg(ds['func'])
        elif ds['cargador'] == 'sklearn_multi':
            X, y = cargar_sklearn_multi(ds['func'])
        elif ds['cargador'] == 'huggingface':
            X, y = cargar_huggingface(ds['id'], ds.get('subset'))
        else:
            print(f"❌ Cargador desconocido: {ds['cargador']}")
            continue
        
        # Mostrar información básica
        print(f"✅ DISPONIBLE")
        print(f"   • Muestras: {X.shape[0] if hasattr(X, 'shape') else len(X)}")
        print(f"   • Características: {X.shape[1] if hasattr(X, 'shape') else len(X.columns)}")
        print(f"   • Tipo target: {y.dtype if hasattr(y, 'dtype') else type(y).__name__}")
        
        # Valores únicos del target para inferir tipo
        unique_vals = np.unique(y)
        n_classes = len(unique_vals)
        print(f"   • Valores únicos en target: {n_classes}")
        
        # Mostrar primeras filas
        print(f"\n   📋 HEAD (primeras 3 filas):")
        if hasattr(X, 'head'):
            print(X.head(3))
        else:
            print(pd.DataFrame(X).head(3))
        
        # ==================================================
        # SUGERENCIA DE MODELO ML (CLAVE PARA PORTAFOLIO)
        # ==================================================
        print(f"\n   🎯 SUGERENCIA PARA PORTAFOLIO:")
        
        # Determinar tipo de problema
        if n_classes == 2:
            problema = "CLASIFICACIÓN BINARIA"
            modelos = [
                "🔹 Regresión Logística (baseline)",
                "🔹 Árbol de Decisión (interpretable)",
                "🔹 Random Forest (robusto)",
                "🔹 XGBoost / LightGBM / CatBoost (competencia)"
            ]
        elif n_classes > 2 and n_classes <= 20:
            problema = "CLASIFICACIÓN MULTICLASE"
            modelos = [
                "🔹 Random Forest (buen baseline)",
                "🔹 XGBoost con objective='multi:softmax'",
                "🔹 LightGBM con objective='multiclass'",
                "🔹 CatBoost con objective='MultiClass'"
            ]
        elif y.dtype in ['float64', 'float32'] or (n_classes > 20 and not all(v in [0,1] for v in unique_vals)):
            problema = "REGRESIÓN"
            modelos = [
                "🔹 Regresión Lineal (baseline)",
                "🔹 Árbol de Regresión (interpretable)",
                "🔹 Random Forest Regressor",
                "🔹 XGBoost / LightGBM / CatBoost (boosting)"
            ]
        else:
            problema = "CLASIFICACIÓN MULTICLASE (muchas clases)"
            modelos = [
                "🔹 Random Forest (bien para muchas clases)",
                "🔹 XGBoost con early stopping",
                "🔹 Redes Neuronales (si hay suficientes datos)"
            ]
        
        print(f"   📌 Tipo de problema: {problema}")
        print(f"   📌 Modelos sugeridos:")
        for m in modelos:
            print(f"      {m}")
        
        # Guardar resultado
        resultados.append({
            "Dataset": ds['nombre'],
            "Disponible": "✅ Sí",
            "Muestras": X.shape[0] if hasattr(X, 'shape') else len(X),
            "Características": X.shape[1] if hasattr(X, 'shape') else len(X.columns),
            "Tipo Problema": problema,
            "Clases/Valores": n_classes if problema != "REGRESIÓN" else "continua"
        })
        
    except Exception as e:
        print(f"❌ NO DISPONIBLE o ERROR")
        print(f"   Error: {str(e)[:150]}")
        resultados.append({
            "Dataset": ds['nombre'],
            "Disponible": "❌ No",
            "Muestras": "-",
            "Características": "-",
            "Tipo Problema": "Error",
            "Clases/Valores": "-"
        })

# ======================================================
# TABLA RESUMEN FINAL
# ======================================================
print("\n" + "="*80)
print("📊 TABLA RESUMEN DE DATASETS VALIDADOS")
print("="*80)

resumen_df = pd.DataFrame(resultados)
print(resumen_df.to_string(index=False))

