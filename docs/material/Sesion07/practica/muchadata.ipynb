# LISTA DE DATASETS A VALIDAR
# ======================================================
datasets_to_test = [
    # === NEGOCIOS / CLASIFICACIÓN BINARIA ===
    {
        "nombre": "Bank Churn (Abandono bancario)",
        "cargador": "openml",
        "id": 46915,
        "descripcion": "Predicción de clientes que abandonan el banco"
    },
    {
        "nombre": "Bank Marketing (Depósito a plazo)",
        "cargador": "openml",
